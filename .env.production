# Variables de entorno para CogniChat - PRODUCCIÓN

# ================================
# CONFIGURACIÓN DE OLLAMA
# ================================
OLLAMA_BASE_URL=https://tu-ollama-service.railway.app
OLLAMA_TIMEOUT=120

# ================================
# MODELOS POR DEFECTO
# ================================
DEFAULT_LLM_MODEL=deepseek-r1:7b
DEFAULT_EMBEDDING_MODEL=nomic-embed-text:latest

# ================================
# CONFIGURACIÓN RAG OPTIMIZADA PARA PRODUCCIÓN
# ================================
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
MAX_RETRIEVAL_DOCS=12
SIMILARITY_THRESHOLD=0.65

# ================================
# CONFIGURACIÓN DE GENERACIÓN
# ================================
MAX_RESPONSE_TOKENS=2500

# ================================
# CONFIGURACIÓN DE ARCHIVOS
# ================================
MAX_FILE_SIZE_MB=50
MAX_UPLOAD_SIZE_MB=100

# ================================
# CONFIGURACIÓN DE LOGS
# ================================
LOG_LEVEL=WARNING
ENABLE_DEBUG_MODE=false

# ================================
# CONFIGURACIÓN DE TRAZABILIDAD
# ================================
ENABLE_CHUNK_LOGGING=false
ENABLE_HISTORY_TRACKING=true

# ================================
# CONFIGURACIÓN DE CACHE
# ================================
CACHE_DIR=./data/cache
MAX_CACHE_SIZE=500
CACHE_EXPIRY_HOURS=12

# ================================
# CONFIGURACIÓN DE ANÁLISIS CUALITATIVO
# ================================
ENABLE_ADVANCED_ANALYSIS=true
MAX_TOPICS=8
MIN_CLUSTER_SIZE=3
DEFAULT_CLUSTERING_METHOD=kmeans
NLTK_DATA_PATH=./data/nltk_data
SPACY_MODEL=es_core_news_sm

# ================================
# CONFIGURACIÓN DE VISUALIZACIONES
# ================================
PLOT_WIDTH=700
PLOT_HEIGHT=500
WORDCLOUD_WIDTH=600
WORDCLOUD_HEIGHT=300
CONCEPT_MAP_ITERATIONS=30

# ================================
# CONFIGURACIÓN DE BASE DE DATOS
# ================================
DB_PATH=./data/cognichat.db
VECTOR_DB_PATH=./data/chroma_db

# ================================
# CONFIGURACIÓN DE UI
# ================================
DEFAULT_LANGUAGE=es
THEME=light

# ================================
# CONFIGURACIÓN DE SEGURIDAD
# ================================
MAX_QUERY_LENGTH=800
RATE_LIMIT_REQUESTS=50
RATE_LIMIT_WINDOW_MINUTES=60

# ================================
# CONFIGURACIÓN DE STREAMLIT PARA PRODUCCIÓN
# ================================
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
STREAMLIT_SERVER_ENABLE_CORS=false
STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=false
STREAMLIT_SERVER_FILE_WATCHER_TYPE=none
STREAMLIT_SERVER_RUN_ON_SAVE=false

# ================================
# CONFIGURACIÓN DE RAILWAY
# ================================
# Estas variables las configura Railway automáticamente:
# PORT=8501
# RAILWAY_ENVIRONMENT=production
# RAILWAY_SERVICE_NAME=cognichat